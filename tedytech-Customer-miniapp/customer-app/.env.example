# ============================================================
# ENVIRONMENT VARIABLE REFERENCE  —  customer-app/.env.example
# ============================================================
# Copy this file to .env.local for local development.
# For production, set these in Vercel → Project → Environment Variables.
# Never commit .env.local or any file containing real secrets.
# ============================================================

# ------------------------------------------------------------------
# REQUIRED — app will not start without this
# ------------------------------------------------------------------

# Convex deployment URL — baked into the Vite bundle at build time.
# Dev URL:  get from `npx convex dev`
# Prod URL: get from the Convex dashboard → your deployment
VITE_CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud

# ------------------------------------------------------------------
# REQUIRED — lead conversion will be broken without these
# ------------------------------------------------------------------

# Telegram bot username — no leading @
# Every inquiry/exchange CTA deep-links to:
#   https://t.me/<VITE_BOT_USERNAME>?start=lead_<id>
VITE_BOT_USERNAME=Micky MobileBot

# Store phone number in E.164 format (country code + number, no spaces)
# Powers the "Call Physical Store" button in the About tab
# Example: +251911234567
VITE_STORE_PHONE=+251911XXXXXX

# Google Maps or Apple Maps deep link for the physical store location
# Powers the "Get Directions" button in the About tab
# Example: https://maps.app.goo.gl/AbCdEfGh
VITE_STORE_MAPS_URL=https://maps.app.goo.gl/YOUR_LINK

# ------------------------------------------------------------------
# OPTIONAL
# ------------------------------------------------------------------

# Set to "dev" to enable verbose [Micky Mobile] debug logs in the console
# Leave unset (or any other value) in production
# VITE_APP_ENVIRONMENT=dev
